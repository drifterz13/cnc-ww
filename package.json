{
  "name": "concert-wow",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "dev": "pnpm --parallel --filter @concert-wow/api --filter @concert-wow/web dev",
    "dev:api": "pnpm --filter @concert-wow/api start:dev",
    "dev:web": "pnpm --filter @concert-wow/web dev",
    "format": "pnpm --recursive --if-present format",
    "lint": "pnpm --recursive --if-present lint",
    "start": "pnpm --filter @concert-wow/api start",
    "start:dev": "pnpm --filter @concert-wow/api start:dev",
    "start:debug": "pnpm --filter @concert-wow/api start:debug",
    "start:prod": "pnpm --filter @concert-wow/api start:prod",
    "test": "pnpm --filter @concert-wow/api test",
    "test:watch": "pnpm --filter @concert-wow/api test:watch",
    "test:cov": "pnpm --filter @concert-wow/api test:cov",
    "test:e2e": "pnpm --filter @concert-wow/api test:e2e",
    "db:gen": "pnpm --filter @concert-wow/api db:gen",
    "db:migrate": "pnpm --filter @concert-wow/api db:migrate",
    "db:reset": "pnpm --filter @concert-wow/api db:reset",
    "db:seed": "pnpm --filter @concert-wow/api db:seed",
    "db:studio": "pnpm --filter @concert-wow/api db:studio"
  }
}
